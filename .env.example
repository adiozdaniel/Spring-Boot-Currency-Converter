# Environment Variables Template
# Copy this file to .env and fill in the actual values
# WARNING: Never commit .env to git!

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_DB=conversions_database
POSTGRES_USER=db_username
POSTGRES_PASSWORD=secure_db_password

# ===========================================
# Main Service Configuration
# ===========================================
MAIN_SERVICE_PORT=8000
SPRING_PROFILES_ACTIVE=development

# ===========================================
# Rate Service Configuration
# ===========================================
RATE_SERVICE_PORT=8080
RATE_SERVICE_API_KEY=rate_service_api_key

# ===========================================
# Config Server Configuration
# ===========================================
CONFIG_SERVER_PORT=8888
CONFIG_SERVER_USERNAME=config-user
CONFIG_SERVER_PASSWORD=change-me-to-strong-password

# Git Repository Configuration
CONFIG_REPO_URI=https://github.com/org/config-repo.git
CONFIG_REPO_BRANCH=main
CONFIG_REPO_USERNAME=git-username
CONFIG_REPO_PASSWORD=git-token-or-password
CONFIG_SEARCH_PATHS={application}

# Keystore Encryption Configuration
# Generate keystore with:
# keytool -genkeypair -alias config-server-key -keyalg RSA -keystore config-server.jks -keysize 2048 -validity 365
KEYSTORE_NAME=config-server.jks
KEYSTORE_PASSWORD=keystore-password
KEYSTORE_ALIAS=config-server-key
KEYSTORE_SECRET=keystore-secret

# ===========================================
# Monitoring Configuration
# ===========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=secure_grafana_password

# ===========================================
# Alertmanager Configuration
# ===========================================
SMTP_FROM=alerts@domain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=email@gmail.com
SMTP_PASSWORD=smtp_password

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR/WEBHOOK/URL
PAGERDUTY_SERVICE_KEY=pagerduty_integration_key

# ===========================================
# Docker Registry
# ===========================================
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=github_username
DOCKER_PASSWORD=github_token

# ===========================================
# SonarQube
# ===========================================
SONAR_TOKEN=sonarqube_token
SONAR_ORGANIZATION=currency-converter
SONAR_HOST_URL=https://sonarcloud.io

# ===========================================
# Jenkins
# ===========================================
JENKINS_ADMIN_PASSWORD=jenkins_admin_password

# ===========================================
# Kubernetes
# ===========================================
KUBERNETES_NAMESPACE=currency-converter
