# Environment Variables Template
# Copy this file to .env and fill in the actual values
# WARNING: Never commit .env to git!

# Config Server Environment Variables
# ===========================================
# Git Repository Configuration
# ===========================================
CONFIG_REPO_URI=https://github.com/org/config-repo.git
CONFIG_REPO_BRANCH=main
CONFIG_REPO_USERNAME=git-username
CONFIG_REPO_PASSWORD=git-token-or-password
CONFIG_SEARCH_PATHS={application}

# ===========================================
# Config Server Security
# ===========================================
CONFIG_SERVER_PORT=8888
CONFIG_SERVER_USERNAME=config-user
CONFIG_SERVER_PASSWORD=change-me-to-strong-password

# ===========================================
# Keystore Encryption Configuration
# ===========================================
# Generate keystore with:
# keytool -genkeypair -alias config-server-key -keyalg RSA -keystore config-server.jks -keysize 2048 -validity 365
KEYSTORE_NAME=config-server.jks
KEYSTORE_PASSWORD=keystore-password
KEYSTORE_ALIAS=config-server-key
KEYSTORE_SECRET=keystore-secret