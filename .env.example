# Environment Variables Template
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env to git!

# Database Configuration
POSTGRES_DB=conversions_database
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_secure_db_password

# Main Service Configuration
MAIN_SERVICE_PORT=8000
SPRING_PROFILES_ACTIVE=development

# Rate Service Configuration
RATE_SERVICE_PORT=8080
RATE_SERVICE_API_KEY=your_rate_service_api_key

# Monitoring Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_password

# Alertmanager Configuration
SMTP_FROM=alerts@your-domain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_smtp_password

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR/WEBHOOK/URL
PAGERDUTY_SERVICE_KEY=your_pagerduty_integration_key

# Docker Registry
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your_github_username
DOCKER_PASSWORD=your_github_token

# SonarQube
SONAR_TOKEN=your_sonarqube_token
SONAR_ORGANIZATION=currency-converter
SONAR_HOST_URL=https://sonarcloud.io

# Jenkins
JENKINS_ADMIN_PASSWORD=your_jenkins_admin_password

# Kubernetes
KUBERNETES_NAMESPACE=currency-converter
