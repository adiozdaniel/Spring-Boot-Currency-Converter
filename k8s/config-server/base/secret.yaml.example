apiVersion: v1
kind: Secret
metadata:
  name: config-server-secret
  labels:
    app: config-server
type: Opaque
stringData:
  # Config server authentication
  username: "config-user"
  password: "REPLACE_WITH_SECURE_PASSWORD"

  # Encryption key (use strong random key in production)
  # Generate with: openssl rand -base64 32
  encrypt-key: "REPLACE_WITH_ENCRYPTION_KEY"

  # Git repository credentials (if private repo)
  repo-username: "REPLACE_WITH_GIT_USERNAME"
  repo-password: "REPLACE_WITH_GIT_TOKEN"
